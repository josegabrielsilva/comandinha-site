# Copie para .env.deploy e preencha (não commite .env.deploy).
#
# IMPORTANTE — FTP_HOST:
#   Use o hostname do SERVIDOR no cPanel → Informações gerais → Nome do servidor
#   Ex.: gator4321.hostgator.com  ou  br1234.hostgator.com.br
#   NÃO use usecomandinha.com.br nem ftp.usecomandinha.com.br
#   (o domínio passa pelo Cloudflare e FTP/SFTP na porta 21/22 não conecta).

FTP_HOST=gatorXXXX.hostgator.com
FTP_USER=seu_usuario_cpanel
FTP_PASSWORD=sua_senha
FTP_PORT=22
FTP_REMOTE_DIR=public_html

# Opcional — purge automático do Cloudflare após deploy
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
