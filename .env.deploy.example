# Copie para .env.deploy e preencha (não commite .env.deploy).
#
# Conta FTP no cPanel (ex.: github@usecomandinha.com.br)
#   FTP_USER=github@usecomandinha.com.br
#   FTP_PORT=21  (FTPS explícito — padrão HostGator)
#
# IMPORTANTE — FTP_HOST no GitHub Actions:
#   Use o hostname do SERVIDOR no cPanel → Informações gerais → Nome do servidor
#   Ex.: br1234.hostgator.com.br
#   NÃO use ftp.usecomandinha.com.br no CI
#   (o domínio passa pelo Cloudflare e FTP na porta 21 não conecta de fora).

FTP_HOST=brXXXX.hostgator.com.br
# Conta FTP com diretório = public_html no cPanel (NÃO use .../github).
# Alternativa: usuário principal do cPanel (abre na home; o script envia para public_html/).
FTP_USER=github@usecomandinha.com.br
FTP_PASSWORD=sua_senha
FTP_PORT=21
FTP_REMOTE_DIR=public_html
# Só se a conta já abrir dentro de public_html (chroot). Senão, deixe vazio.
# FTP_ASSUME_CHROOT_PUBLIC_HTML=true

# Opcional — purge automático do Cloudflare após deploy
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
