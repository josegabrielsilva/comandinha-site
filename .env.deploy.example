# Copie para .env.deploy e preencha (não commite .env.deploy).
# HostGator → cPanel → FTP Accounts (ou credenciais da conta principal).

FTP_HOST=ftp.usecomandinha.com.br
FTP_USER=seu_usuario_ftp
FTP_PASSWORD=sua_senha_ftp
FTP_REMOTE_DIR=public_html

# Opcional — evita esperar cache do Cloudflare (dash.cloudflare.com → API Tokens)
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
